# All keys use the VITE_ prefix so Vite exposes them via import.meta.env
# Copy this file to .env.local and fill in your keys

# Claude API Key — get from console.anthropic.com
VITE_CLAUDE_API_KEY=

# Nano Banana API Key — get from nanobnana.com/dashboard/api-keys
VITE_NANOBANANA_API_KEY=

# Kling API — get Access Key + Secret Key from klingai.com
# (JWT is generated automatically from these two)
VITE_KLING_ACCESS_KEY=
VITE_KLING_SECRET_KEY=

# Gemini API Key — get from aistudio.google.com
VITE_GEMINI_API_KEY=

# ElevenLabs TTS API Key — get from elevenlabs.io
VITE_ELEVENLABS_API_KEY=

# Supabase — get from supabase.com/dashboard/project/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
